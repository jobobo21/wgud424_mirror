<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wgud424_maui.Views.TermView"
             x:Name="TermPage"
             Title="TermPage">

    <!-- Clicked="SaveDatesButton_Clicked" - Add this event handler later -->

    <ScrollView>
        <VerticalStackLayout Margin="20, 10, 20, 20">

            <!-- Term Date Range Section -->
            <Frame BackgroundColor="White" 
               CornerRadius="10" 
               HasShadow="True"
               Padding="20"
               Margin="0,0,0,20">
                <VerticalStackLayout Spacing="15">
                    <Label Text="Term Duration" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       TextColor="DarkBlue"
                       HorizontalOptions="Center"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Start Date -->
                        <VerticalStackLayout Grid.Column="0" Spacing="5" Margin="0,0,10,0">
                            <Label Text="Start Date" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="DarkGray"/>
                            <Label x:Name="StartDatePicker" 
                                   TextColor="Black"
                                   FontSize="14"/>
                        </VerticalStackLayout>

                        <!-- End Date -->
                        <VerticalStackLayout Grid.Column="1" Spacing="5" Margin="10,0,0,0">
                            <Label Text="End Date" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="DarkGray"/>
                            <Label x:Name="EndDatePicker" 
                                   TextColor="Black"
                                   FontSize="14"/>
                        </VerticalStackLayout>
                    </Grid>

                    <Button x:Name="AddCourse_btn" Text="Add Course" CornerRadius="20" Clicked="AddCourse_btn_Clicked"/>
                    <Button x:Name="DeleteTerm_btn" BackgroundColor="Crimson" CornerRadius="20" Text="Delete Term" Clicked="DeleteTerm_btn_Clicked"/>
                </VerticalStackLayout>
            </Frame>

            <!-- Course Statistics Grid -->
            <Grid x:Name="CourseStatsGrid" Margin="0,20,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Frame x:Name="TotalFrame" Grid.Column="0" BackgroundColor="LightBlue" Padding="10" Margin="5">
                    <StackLayout>
                        <Label x:Name="TotalCoursesLabel" Text="0" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Total Courses" FontSize="12" HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>
                <Frame x:Name="ActiveFrame" Grid.Column="1" BackgroundColor="LightGreen" Padding="10" Margin="5">
                    <StackLayout>
                        <Label x:Name="ActiveCoursesLabel" Text="0" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Active" FontSize="12" HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>
                <Frame x:Name="CompletedFrame" Grid.Column="2" BackgroundColor="LightCoral" Padding="10" Margin="5">
                    <StackLayout>
                        <Label x:Name="CompletedCoursesLabel" Text="0" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="Completed" FontSize="12" HorizontalOptions="Center"/>
                    </StackLayout>
                </Frame>
            </Grid>

            <Grid x:Name="CourseGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
            </Grid>

            <!-- Courses Section Header -->
            <Label Text="Courses" 
               FontSize="20" 
               FontAttributes="Bold"
               TextColor="DarkBlue"
               Margin="0,20,0,15"
               HorizontalOptions="Start"/>

            <!-- CollectionView instead of ListView -->
            <!-- CollectionView with Grid instead of Frame -->

            <CollectionView x:Name="CourseListView" 
                SelectionMode="Single"
                SelectionChanged="CourseListView_SelectionChanged"
                            >
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White"
                    StrokeThickness="1"
                    Stroke="LightGray"
                    StrokeShape="RoundRectangle 8"
                    Margin="0,5,0,10">
                            <StackLayout Padding="15">
                                <Label Text="{Binding Course.code}" 
                           FontSize="16" 
                           FontAttributes="Bold"
                           TextColor="DarkBlue"/>
                                <Label Text="{Binding Course.name}" 
                           FontSize="12" 
                           TextColor="Gray"
                           Margin="0,5,0,0"/>
                                <HorizontalStackLayout>
                                    <Label Text="CUs:" 
                                            FontSize="12" 
                                            TextColor="Gray"
                                            Margin="0,5,0,0"/>
                                    <Label Text="{Binding Course.competency_units}" 
                                            FontSize="12" 
                                            TextColor="Gray"
                                            Margin="0,5,0,0"/>      
                                </HorizontalStackLayout>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
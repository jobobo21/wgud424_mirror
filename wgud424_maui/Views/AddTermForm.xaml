<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wgud424_maui.Views.AddTermForm"
             x:Name="ContentPage"
             Title="Add New Term"
             BackgroundColor="#F8F9FA">

    <ScrollView>
        <Grid Padding="20" RowSpacing="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header Section -->
            <Frame Grid.Row="0" 
                   BackgroundColor="White" 
                   CornerRadius="15" 
                   HasShadow="True"
                   Padding="20,15">
                <StackLayout>
                    <Label Text="📅" 
                           FontSize="32" 
                           HorizontalOptions="Center" 
                           Margin="0,0,0,10"/>
                    <Label Text="Create Academic Term" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="#2C3E50" 
                           HorizontalOptions="Center"/>
                    <Label Text="Set the start and end dates for your new academic term" 
                           FontSize="14" 
                           TextColor="#7F8C8D" 
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"/>
                </StackLayout>
            </Frame>

            <!-- Form Section -->
            <Frame Grid.Row="1" 
                   BackgroundColor="White" 
                   CornerRadius="15" 
                   HasShadow="True" 
                   Padding="25"
                   Margin="0,10">
                <VerticalStackLayout Spacing="25">

                    <!-- Start Date Section -->
                    <StackLayout Spacing="10">
                        <Label Text="Start Date" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               TextColor="#34495E"/>
                        <Frame BackgroundColor="#ECF0F1" 
                               CornerRadius="10" 
                               Padding="15,10" 
                               HasShadow="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" 
                                       Text="📅" 
                                       FontSize="18" 
                                       VerticalOptions="Center" 
                                       Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="1"
                                           x:Name="StartDatePicker"
                                           BackgroundColor="Transparent"
                                           TextColor="#2C3E50"
                                           FontSize="16"/>
                            </Grid>
                        </Frame>
                    </StackLayout>

                    <!-- End Date Section -->
                    <StackLayout Spacing="10">
                        <Label Text="End Date" 
                               FontSize="16" 
                               FontAttributes="Bold" 
                               TextColor="#34495E"/>
                        <Frame BackgroundColor="#ECF0F1" 
                               CornerRadius="10" 
                               Padding="15,10" 
                               HasShadow="False">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Label Grid.Column="0" 
                                       Text="📅" 
                                       FontSize="18" 
                                       VerticalOptions="Center" 
                                       Margin="0,0,10,0"/>
                                <DatePicker Grid.Column="1"
                                           x:Name="EndDatePicker"
                                           BackgroundColor="Transparent"
                                           TextColor="#2C3E50"
                                           FontSize="16"/>
                            </Grid>
                        </Frame>
                    </StackLayout>

                    <!-- Date Range Info -->
                    <Frame BackgroundColor="#E8F6F3" 
                           CornerRadius="8" 
                           Padding="15" 
                           HasShadow="False">
                        <StackLayout Orientation="Horizontal" Spacing="10">
                            <Label Text="💡" FontSize="16" VerticalOptions="Center"/>
                            <Label Text="Make sure the end date is after the start date" 
                                   FontSize="12" 
                                   TextColor="#16A085" 
                                   VerticalOptions="Center"
                                   LineBreakMode="WordWrap"/>
                        </StackLayout>
                    </Frame>

                </VerticalStackLayout>
            </Frame>

            <!-- Action Buttons -->
            <StackLayout Grid.Row="2" Spacing="15" Margin="0,10">
                <Button x:Name="CreateTerm_btn" 
                        Text="Create Term" 
                        Clicked="CreateTerm_btn_Clicked"
                        BackgroundColor="#3498DB"
                        TextColor="White"
                        FontSize="16"
                        FontAttributes="Bold"
                        CornerRadius="25"
                        HeightRequest="50"/>

                <Button Text="Cancel" 
                        BackgroundColor="Transparent"
                        TextColor="#95A5A6"
                        FontSize="14"
                        BorderColor="#BDC3C7"
                        BorderWidth="1"
                        CornerRadius="25"
                        HeightRequest="45"/>
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentPage>
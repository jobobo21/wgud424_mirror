<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wgud424_maui.Views.LoginModal"
             Title="Login"
             BackgroundColor="#003057">
    <VerticalStackLayout>
        <Label 
            Text="Welcome To WGU"
            VerticalOptions="Center" 
            FontSize="20"
            TextColor="White"
            HorizontalOptions="Center" />
        <Label 
            Text="Course Scheduling App"
            VerticalOptions="Center" 
            FontSize="20"
            TextColor="White"
            HorizontalOptions="Center" />
        <Label 
         Text="Please Login to continue"
         VerticalOptions="Center" 
         FontSize="14"
         HorizontalOptions="Center" 
         TextColor="White"
         Margin="0, 20, 0, 100"
         />

        <Label 
   Text="Email"
   VerticalOptions="Center" 
   FontSize="18"
   HorizontalOptions="Start" 
   TextColor="White"
   Margin="15, 20, 0, 1"/>

        <Entry Background="LightGray" Margin="15, 10, 15, 10" x:Name="Emailentry"/>

        <Label 
    Text="Password"
    VerticalOptions="Center" 
    FontSize="18"
    HorizontalOptions="Start" 
    TextColor="White"
    Margin="15, 20, 0, 1"/>

        <Entry Background="LightGray" Margin="15, 10, 15, 10" IsPassword="True" x:Name="PasswordEntry"/>

        <Button BackgroundColor="LightGray" Text="Login" TextColor="#003057" x:Name="LoginBtn" Clicked="LoginBtn_Clicked"/>

    </VerticalStackLayout>
</ContentPage>